# Root-level ignores
.vite/
node_modules/
build/
.dart_tool/

# Firebase emulator/debug logs
firebase-debug.log*
firestore-debug.log*
ui-debug.log*

# OS/editor
.DS_Store
Thumbs.db

# Firebase service account key (never commit)
serviceAccountKey.json
**/serviceAccountKey.json

# Environment files with secrets (keep .env.example templates)
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# Flutter
.dart_tool/
**/build/
*.log
.flutter-plugins
.flutter-plugins-dependencies

# Firebase cache
.firebase/

# Claude runtime
.claude/scheduled_tasks.lock
.claude/*.lock
